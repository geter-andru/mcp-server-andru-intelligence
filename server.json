{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.geter-andru/andru-intelligence",
  "title": "Andru Revenue Intelligence",
  "description": "19 buyer intelligence tools for technical founders selling to enterprises.",
  "version": "1.4.0",
  "websiteUrl": "https://platform.andru-ai.com",
  "repository": {
    "url": "https://github.com/geter-andru/mcp-server-andru-intelligence.git",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "npm",
      "identifier": "mcp-server-andru-intelligence",
      "version": "1.4.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "ANDRU_API_KEY",
          "description": "Your Andru Platform API key. Get one at https://platform.andru-ai.com/settings/api-keys",
          "isRequired": true,
          "isSecret": true
        },
        {
          "name": "ANDRU_API_URL",
          "description": "Andru API base URL (default: https://hs-andru-test.onrender.com)",
          "isRequired": false,
          "default": "https://hs-andru-test.onrender.com"
        }
      ]
    },
    {
      "registryType": "npm",
      "identifier": "mcp-server-andru-intelligence",
      "version": "1.4.0",
      "transport": {
        "type": "http",
        "url": "https://mcp-server-andru-intelligence.onrender.com/mcp"
      },
      "environmentVariables": [
        {
          "name": "ANDRU_API_KEY",
          "description": "Your Andru Platform API key. Get one at https://platform.andru-ai.com/settings/api-keys",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
}
